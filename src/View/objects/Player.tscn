[sub_resource type="GDScript" id="GDScript_t1rct"]
resource_name = "Player"
script/source = "class_name Player
extends CharacterBody2D

@export var move_speed: float = 120.0
@export var max_health: int = 100

var health: int
var is_dead: bool = false

@onready var head: AnimatedSprite2D = $Head
@onready var gun: AnimatedSprite2D = $Gun

func _ready() -> void:
	health = max_health
	head.z_index = 1
	gun.z_index = 0

func _physics_process(_delta: float) -> void:
	if is_dead:
		return

	var direction := Input.get_vector(\"left\", \"right\", \"up\", \"down\")
	velocity = direction * move_speed
	move_and_slide()

func _process(_delta: float) -> void:
	update_head_direction()

func update_head_direction() -> void:
	var mouse_pos: Vector2 = get_global_mouse_position()
	var dir: Vector2 = (mouse_pos - global_position).normalized()
	var angle: float = rad_to_deg(dir.angle())

	if angle < 0:
		angle += 360.0

	if angle >= 337.5 or angle < 22.5:
		head.frame = 0
		gun.frame = 0
		gun.position = Vector2(4, 1)
	elif angle < 67.5:
		head.frame = 1
		gun.frame = 1
		gun.position = Vector2(3, 2)
	elif angle < 112.5:
		head.frame = 2
		gun.frame = 2
		gun.position = Vector2(0, 3)
	elif angle < 157.5:
		head.frame = 3
		gun.frame = 3
		gun.position = Vector2(-3, 2)
	elif angle < 202.5:
		head.frame = 4
		gun.frame = 4
		gun.position = Vector2(-4, 1)
	elif angle < 247.5:
		head.frame = 5
		gun.frame = 5
		gun.position = Vector2(-3, -1)
	elif angle < 292.5:
		head.frame = 6
		gun.frame = 6
		gun.position = Vector2(0, -2)
	else:
		head.frame = 7
		gun.frame = 7
		gun.position = Vector2(3, -1)
"

