[sub_resource type="GDScript" id="GDScript_t1rct"]
resource_name = "Player"
script/source = "class_name Player
extends CharacterBody2D

@export var move_speed: float = 120.0
@export var max_health: int = 100

var health: int
var is_dead: bool = false
var facing: String = \"down\"

@onready var animated_sprite: AnimatedSprite2D = $AnimatedSprite2D

func _ready() -> void:
	health = max_health

func _physics_process(_delta: float) -> void:
	if is_dead:
		return

	var direction := Input.get_vector(\"left\", \"right\", \"up\", \"down\")
	velocity = direction * move_speed
	move_and_slide()

	_update_facing(direction)
	_update_animation(direction)

func take_damage(amount: int) -> void:
	if is_dead:
		return

	health -= amount
	if health <= 0:
		die()

func heal(amount: int) -> void:
	if is_dead:
		return

	health = min(health + amount, max_health)

func die() -> void:
	is_dead = true
	velocity = Vector2.ZERO
	animated_sprite.play(\"idle_\" + facing) # later replace with death anim

func _update_facing(direction: Vector2) -> void:
	if direction == Vector2.ZERO:
		return

	if abs(direction.x) > abs(direction.y):
		if direction.x > 0:
			facing = \"right\"
		else:
			facing = \"left\"
	else:
		if direction.y > 0:
			facing = \"down\"
		else:
			facing = \"up\"

func _update_animation(direction: Vector2) -> void:
	if direction == Vector2.ZERO:
		animated_sprite.play(\"idle_\" + facing)
	else:
		animated_sprite.play(\"walk_\" + facing)
"

