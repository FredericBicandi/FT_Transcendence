[sub_resource type="GDScript" id="GDScript_hh7td"]
resource_name = "Sniper"
script/source = "class_name SniperRifle
extends BaseWeapon

# This built-in script exists only to point the shared BaseWeapon logic at the sniper data row.
const WeaponDataRef = preload(\"res://src/Scripts/Weapons/weapon_data.gd\")

func _ready() -> void:
	# Assign the sniper id so BaseWeapon reads the correct damage, reload, recoil, and frame offsets.
	weapon_id = \"Sniper\"
	super._ready()
"

