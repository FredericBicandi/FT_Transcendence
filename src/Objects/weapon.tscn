[sub_resource type="GDScript" id="GDScript_ssn77"]
resource_name = "Assult_Riifle"
script/source = "class_name AFRifle
extends BaseWeapon

# The weapon scene reuses BaseWeapon for behavior; this tiny built-in script only selects the data entry to use.
const WeaponDataRef = preload(\"res://src/Scripts/Weapons/weapon_data.gd\")

func _ready() -> void:
	# Bind this node to the default assault rifle config before BaseWeapon initializes visuals and ammo.
	weapon_id = WeaponDataRef.DEFAULT_WEAPON_ID
	super._ready()
"

