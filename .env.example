# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local development URL. Set this to the deployed origin in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional when the WebSocket server is on another origin. By default the
# dashboard connects to /ws/dashboard on the website origin.
NEXT_PUBLIC_DASHBOARD_WS_URL=ws://localhost:5000/ws/dashboard
