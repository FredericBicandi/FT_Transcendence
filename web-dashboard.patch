+function createDashboardWebSocketUrl(accessToken?: string) {
+  const configuredUrl =
+    process.env.NEXT_PUBLIC_DASHBOARD_WEBSOCKET_URL?.trim();
+  const url = configuredUrl
+    ? new URL(configuredUrl)
+    : new URL(
+        DASHBOARD_WEBSOCKET_PATH,
+        `${window.location.protocol === "https:" ? "wss:" : "ws:"}//${window.location.host}`,
+      );
+
+  if (accessToken) {
+    url.searchParams.set("access_token", accessToken);
+  }
+
+  return url.toString();
+}
+
+function readDashboardMessage(value: unknown) {
+  if (typeof value !== "object" || value === null) {
+    return null;
+  }
+
+  const message = value as Record<string, unknown>;
+
+  if (message.type === "online_count") {
+    return typeof message.count === "number" &&
+      Number.isFinite(message.count) &&
+      message.count >= 0
+      ? {
+          type: "online_count" as const,
+          count: Math.floor(message.count),
+        }
+      : null;
+  }
+
+  if (message.type === "global_chat") {
+    return typeof message.message_id === "string" &&
+      typeof message.player_id === "string" &&
+      typeof message.playerName === "string" &&
+      typeof message.content === "string" &&
+      typeof message.sentAt === "string"
+      ? {
+          type: "global_chat" as const,
+          message: {
+            message_id: message.message_id,
+            player_id: message.player_id,
+            playerName: message.playerName,
+            content: message.content,
+            sentAt: message.sentAt,
+          },
+        }
+      : null;
+  }
+
+  if (message.type === "ping") {
+    return { type: "ping" as const };
+  }
+
+  return null;
+}
